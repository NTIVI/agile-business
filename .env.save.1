# ============================================================
# Agile Business — переменные окружения
# Скопируйте на сервер как /var/www/agile-business/.env и заполните значения.
# ============================================================

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=agile_business

# --- HTTP ---
# На сервере обычно 3010 за nginx; локально можно 3000
PORT=3010

# --- Сессии и вход в админку ---
# SESSION_SECRET: для продакшена задайте длинную случайную строку (иначе сессии сбросятся при рестарте)
SESSION_SECRET=229d1d5f7674c3eab515af7a2183f82ccd83e605aab71e2d73d0badf67408d84d5adf03d47eb4cd0e60c02a7e0812b55

# Пароль для первичного сида БД (setup-db.js); сам вход в админку — через admin_users в PostgreSQL
ADMIN_PASSWORD=admin123

# Для локальной разработки оставляем пустым; на проде можно указать .agile-business-pro.com
COOKIE_DOMAIN=

# Явный хост админки (опционально; если не задан — подходит любой admin.*)
ADMIN_HOST=admin.agile-business-pro.com

# --- Telegram (опционально; актуальные токен и чаты удобно хранить в админке → settings) ---
TG_BOT_TOKEN=
TG_CHAT_ID=

# --- Отладка ---
# PERF_LOG=1 — логировать медленные запросы в консоль
PERF_LOG=0

