# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=agile_business

# Telegram
TG_BOT_TOKEN=
TG_CHAT_ID=

# Admin
ADMIN_PASSWORD=admin123
SESSION_SECRET=
# Поддомен админки (опционально; иначе любой хост admin.*)
# ADMIN_HOST=admin.agile-business-pro.com
# Cookie сессии для всех поддоменов (с точкой в начале). Пусто = только текущий хост.
# COOKIE_DOMAIN=.agile-business-pro.com

# Server (если на :3000 другой сервис и в ответах 429 + X-RateLimit-* без X-AB-App — смените порт)
PORT=3000
# На проде за Nginx/HTTPS включите, иначе сессия и вход могут вести себя непредсказуемо
# NODE_ENV=production
